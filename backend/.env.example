# GadiSewa Backend Environment Configuration
# Copy this file to .env and fill in real values

# Google Gemini API Key (for AI features)
GEMINI_API_KEY=your-gemini-api-key-here

# Database URL (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./gadisewa.db
# DATABASE_URL=postgresql://user:password@host:5432/gadisewa

# Admin access token (REQUIRED - set a strong random value)
ADMIN_ACCESS_TOKEN=change-this-to-a-strong-random-token

# Application settings
PORT=8000

# CORS allowed origins (comma-separated)
# Add your production frontend URL here (e.g., https://gadisewa.com,https://www.gadisewa.com)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://gadisewa.com,https://www.gadisewa.com
